# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored — secrets never get committed.

# Contact form email endpoint (optional).
# Create a free form at https://formspree.io → copy its endpoint URL here.
# When set, the contact form POSTs messages there (they arrive in your inbox).
# When unset, the form falls back to opening the visitor's mail app.
VITE_CONTACT_ENDPOINT=https://formspree.io/f/mdaqgdpw
